{
  "name": "wmux",
  "version": "0.1.2",
  "private": true,
  "description": "A single-user browser terminal multiplexer for private networks.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gisenberg/wmux.git"
  },
  "bugs": {
    "url": "https://github.com/gisenberg/wmux/issues"
  },
  "homepage": "https://github.com/gisenberg/wmux#readme",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server/index.ts --dev",
    "build": "npm run build:client && npm run build:server",
    "build:client": "node scripts/build-client.mjs",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "audit:sessions": "node scripts/wmux-session-audit",
    "test": "node --import tsx --test test/*.test.ts",
    "test:e2e": "playwright test && playwright test --config=playwright.auth.config.ts",
    "test:e2e:chromium": "playwright test --project=chromium --project=mobile-chromium",
    "test:e2e:auth": "playwright test --config=playwright.auth.config.ts",
    "docs:screenshots": "playwright test e2e/docs-screenshots.spec.ts --project=chromium --project=mobile-chromium",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "check:scripts": "node scripts/check-scripts.mjs",
    "check": "npm test && npm run typecheck && npm run check:scripts && npm run build"
  },
  "dependencies": {
    "@fontsource/fira-code": "^5.2.7",
    "@vitejs/plugin-react": "^4.7.0",
    "ghostty-web": "file:vendor/ghostty-web-pr169/ghostty-web-0.4.1-pr169-faf6fbd-wmux3.tgz",
    "lucide-react": "^0.468.0",
    "node-pty": "^1.0.0",
    "tsx": "^4.20.5",
    "vite": "^7.2.4",
    "ws": "^8.18.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.19.1",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.18.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^7.0.2"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
