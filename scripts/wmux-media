#!/usr/bin/env bash
set -euo pipefail

wmux_url="${WMUX_URL:-}"
if [[ -z "${wmux_url}" && -r "${HOME}/.wmux/url" ]]; then
  # ~/.wmux/url is persisted alongside ~/.wmux/token by wmux.
  wmux_url="$(tr -d '[:space:]' < "${HOME}/.wmux/url")"
fi
wmux_url="${wmux_url:-http://127.0.0.1:3478}"
pane_id="${WMUX_PANE_ID:-}"
workspace_id="${WMUX_WORKSPACE_ID:-}"
tab_id="${WMUX_TAB_ID:-}"
mime_type=""
name=""
file_path=""
mode="${WMUX_MEDIA_MODE:-auto}"

usage() {
  cat >&2 <<'EOF'
Usage: wmux-media [--url <url>] [--pane <id>] [--workspace <id>] [--tab <id>] [--mime <type>] [--name <name>] [--mode auto|kitty|http] <file>
EOF
}

load_wmux_token() {
  local token="" token_file="" scoped=0 env_configured=0 env_token=""
  if [[ "${WMUX_HELPER_TOKEN+x}" == x ]]; then
    env_token="${WMUX_HELPER_TOKEN}"; env_configured=1
    [[ "${env_token}" =~ ^[A-Za-z0-9_-]{32,256}$ ]] || { echo "wmux-media: configured helper token is empty or malformed" >&2; return 1; }
  fi
  if [[ "${WMUX_HELPER_TOKEN_PATH+x}" == x ]]; then token_file="${WMUX_HELPER_TOKEN_PATH}"; scoped=1
  elif [[ -e "${HOME}/.wmux/helper-token" ]]; then token_file="${HOME}/.wmux/helper-token"; scoped=1
  fi
  if [[ -n "${token_file}" ]]; then
    [[ -f "${token_file}" && -r "${token_file}" ]] || { echo "wmux-media: configured helper token file is unreadable" >&2; return 1; }
    token="$(tr -d '[:space:]' < "${token_file}")"
  fi
  if [[ "${scoped}" -eq 1 ]]; then
    [[ "${token}" =~ ^[A-Za-z0-9_-]{32,256}$ ]] || { echo "wmux-media: configured helper token is empty or malformed" >&2; return 1; }
    printf '%s' "${token}"
    return
  fi
  if [[ "${env_configured}" -eq 1 ]]; then printf '%s' "${env_token}"; return; fi
  [[ "${WMUX_BROWSER_AUTH_MODE:-shared-or-login}" == "shared-or-login" ]] || return
  token="${WMUX_TOKEN:-}"
  if [[ -z "${token}" ]]; then
    token_file="${WMUX_TOKEN_PATH:-${HOME}/.wmux/token}"
    [[ -r "${token_file}" ]] && token="$(tr -d '[:space:]' < "${token_file}")"
  fi
  printf '%s' "${token}"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --url)
      wmux_url="${2:?--url requires a value}"
      shift 2
      ;;
    --pane)
      pane_id="${2:?--pane requires a value}"
      shift 2
      ;;
    --workspace)
      workspace_id="${2:?--workspace requires a value}"
      shift 2
      ;;
    --tab)
      tab_id="${2:?--tab requires a value}"
      shift 2
      ;;
    --mime)
      mime_type="${2:?--mime requires a value}"
      shift 2
      ;;
    --name)
      name="${2:?--name requires a value}"
      shift 2
      ;;
    --mode)
      mode="${2:?--mode requires a value}"
      case "${mode}" in
        auto|kitty|http) ;;
        *)
          echo "invalid --mode: ${mode}" >&2
          usage
          exit 2
          ;;
      esac
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      if [[ -z "${file_path}" ]]; then
        file_path="$1"
        shift
      else
        echo "unknown argument: $1" >&2
        usage
        exit 2
      fi
      ;;
  esac
done

if [[ -z "${file_path}" || ! -f "${file_path}" ]]; then
  usage
  exit 2
fi

if [[ -z "${name}" ]]; then
  name="$(basename "${file_path}")"
fi

if [[ -z "${mime_type}" ]]; then
  mime_type="$(file -b --mime-type "${file_path}" 2>/dev/null || true)"
fi
if [[ -z "${mime_type}" ]]; then
  mime_type="application/octet-stream"
fi

is_image=0
case "${mime_type}" in
  image/*) is_image=1 ;;
esac

if [[ "${mode}" != "http" && "${is_image}" -eq 1 ]] && command -v kitten >/dev/null 2>&1; then
  if kitten icat --transfer-mode=stream --passthrough=tmux --align=left --engine=builtin --stdin=no "${file_path}"; then
    exit 0
  fi
  if [[ "${mode}" == "kitty" ]]; then
    exit 1
  fi
fi

if [[ "${mode}" == "kitty" ]]; then
  echo "wmux-media: kitten is not available or could not display ${file_path}" >&2
  exit 1
fi

WMUX_MEDIA_FILE="${file_path}" \
WMUX_MEDIA_NAME="${name}" \
WMUX_MEDIA_MIME="${mime_type}" \
WMUX_MEDIA_PANE="${pane_id}" \
WMUX_MEDIA_WORKSPACE="${workspace_id}" \
WMUX_MEDIA_TAB="${tab_id}" \
wmux_token="$(load_wmux_token)"
auth_header=()
if [[ -n "${wmux_token}" ]]; then
  auth_header=(-H "Authorization: Bearer ${wmux_token}")
fi

node <<'NODE' | curl -fsS -H "content-type: application/json" "${auth_header[@]}" --data-binary @- "${wmux_url%/}/api/media" >/dev/null
const fs = require("node:fs");

const payload = {
  name: process.env.WMUX_MEDIA_NAME,
  mimeType: process.env.WMUX_MEDIA_MIME,
  data: fs.readFileSync(process.env.WMUX_MEDIA_FILE).toString("base64"),
};
if (process.env.WMUX_MEDIA_PANE) payload.paneId = process.env.WMUX_MEDIA_PANE;
if (process.env.WMUX_MEDIA_WORKSPACE) payload.workspaceId = process.env.WMUX_MEDIA_WORKSPACE;
if (process.env.WMUX_MEDIA_TAB) payload.tabId = process.env.WMUX_MEDIA_TAB;
process.stdout.write(JSON.stringify(payload));
NODE
