#!/usr/bin/env python3
import argparse
import base64
import ctypes
import hashlib
import hmac
import json
import os
import re
import shutil
import signal
import subprocess
import sys
import threading
import time
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from typing import Any, Callable
from urllib.parse import parse_qs, unquote, urlparse


RELEASE_VERSION = "__WMUX_WINDOWS_AGENT_RELEASE_VERSION__"
PROTOCOL_VERSION = 4
DEFAULT_REPLAY_BYTES = 2 * 1024 * 1024
MAX_PASTE_IMAGE_BYTES = 8 * 1024 * 1024
PASTE_IMAGE_TTL_SECONDS = 60 * 60
BACKEND_CONPTY = "conpty"
BACKEND_STDIO = "stdio"

LOCAL_TERMINAL_QUERY_RESPONSES = {
    b"\x1b[c": b"\x1b[?62;22c",
    b"\x1b[0c": b"\x1b[?62;22c",
    b"\x1b[5n": b"\x1b[0n",
}

OSC7_PATTERN = re.compile(rb"\x1b\]7;file://([^\x07\x1b]*)(?:\x07|\x1b\\)")

JOB_OBJECT_LIMIT_KILL_ON_JOB_CLOSE = 0x00002000
JOB_OBJECT_EXTENDED_LIMIT_INFORMATION = 9
PROCESS_TERMINATE = 0x0001
PROCESS_SET_QUOTA = 0x0100
AGENT_RESTART_EXIT_CODE = 75


class AgentDrainingError(RuntimeError):
    pass


def paste_image_root(config: dict[str, Any]) -> str:
    configured = config_string(config, "pasteImageDir")
    local_app_data = os.environ.get("LOCALAPPDATA") or os.path.join(os.path.expanduser("~"), "AppData", "Local")
    return os.path.abspath(os.path.expandvars(configured) if configured else os.path.join(local_app_data, "wmux", "paste-images"))


def paste_image_prefix(session_id: str, stage_id: str) -> str:
    pane_digest = hashlib.sha256(session_id.encode("utf-8")).hexdigest()[:24]
    return f"{pane_digest}-{stage_id}"


def sweep_paste_images(config: dict[str, Any]) -> None:
    root = paste_image_root(config)
    if not os.path.isdir(root):
        return
    cutoff = time.time() - PASTE_IMAGE_TTL_SECONDS
    for name in os.listdir(root):
        if not re.fullmatch(r"[0-9a-f]{24}-paste-[0-9a-f]{36}\.(png|jpg|webp|gif)", name):
            continue
        target = os.path.join(root, name)
        try:
            if os.path.isfile(target) and os.path.getmtime(target) < cutoff:
                os.remove(target)
        except OSError:
            pass


def validate_paste_image(data: bytes, extension: str) -> bool:
    if extension == "png":
        return data.startswith(b"\x89PNG\r\n\x1a\n")
    if extension == "jpg":
        return data.startswith(b"\xff\xd8\xff")
    if extension == "gif":
        return data.startswith((b"GIF87a", b"GIF89a"))
    if extension == "webp":
        return len(data) >= 12 and data[:4] == b"RIFF" and data[8:12] == b"WEBP"
    return False


def stage_paste_image(
    config: dict[str, Any], session_id: str, stage_id: str, extension: str, data: bytes
) -> dict[str, Any]:
    if not re.fullmatch(r"paste-[0-9a-f]{36}", stage_id) or extension not in ("png", "jpg", "webp", "gif"):
        raise ValueError("invalid_stage")
    if not data or len(data) > MAX_PASTE_IMAGE_BYTES or not validate_paste_image(data, extension):
        raise ValueError("invalid_image")
    root = paste_image_root(config)
    os.makedirs(root, mode=0o700, exist_ok=True)
    try:
        os.chmod(root, 0o700)
    except OSError:
        pass
    sweep_paste_images(config)
    target = os.path.join(root, f"{paste_image_prefix(session_id, stage_id)}.{extension}")
    descriptor = os.open(target, os.O_WRONLY | os.O_CREAT | os.O_EXCL, 0o600)
    try:
        with os.fdopen(descriptor, "wb") as handle:
            handle.write(data)
            handle.flush()
            os.fsync(handle.fileno())
    except Exception:
        try:
            os.remove(target)
        except OSError:
            pass
        raise
    try:
        os.chmod(target, 0o600)
    except OSError:
        pass
    return {
        "stageId": stage_id,
        "targetPath": target,
        "bytes": len(data),
        "expiresAt": int((time.time() + PASTE_IMAGE_TTL_SECONDS) * 1000),
    }


def delete_paste_image(config: dict[str, Any], session_id: str, stage_id: str) -> bool:
    root = paste_image_root(config)
    if not os.path.isdir(root) or not re.fullmatch(r"paste-[0-9a-f]{36}", stage_id):
        return False
    prefix = paste_image_prefix(session_id, stage_id) + "."
    removed = False
    for name in os.listdir(root):
        if not name.startswith(prefix):
            continue
        try:
            os.remove(os.path.join(root, name))
            removed = True
        except OSError:
            pass
    return removed


def delete_session_paste_images(config: dict[str, Any], session_id: str) -> None:
    root = paste_image_root(config)
    if not os.path.isdir(root):
        return
    prefix = hashlib.sha256(session_id.encode("utf-8")).hexdigest()[:24] + "-paste-"
    for name in os.listdir(root):
        if name.startswith(prefix):
            try:
                os.remove(os.path.join(root, name))
            except OSError:
                pass


class WindowsJobApi:
    def __init__(self) -> None:
        if os.name != "nt":
            raise RuntimeError("Windows Job Objects are only available on Windows")
        from ctypes import wintypes

        class JobObjectBasicLimitInformation(ctypes.Structure):
            _fields_ = [
                ("PerProcessUserTimeLimit", ctypes.c_int64),
                ("PerJobUserTimeLimit", ctypes.c_int64),
                ("LimitFlags", wintypes.DWORD),
                ("MinimumWorkingSetSize", ctypes.c_size_t),
                ("MaximumWorkingSetSize", ctypes.c_size_t),
                ("ActiveProcessLimit", wintypes.DWORD),
                ("Affinity", ctypes.c_size_t),
                ("PriorityClass", wintypes.DWORD),
                ("SchedulingClass", wintypes.DWORD),
            ]

        class IoCounters(ctypes.Structure):
            _fields_ = [
                ("ReadOperationCount", ctypes.c_uint64),
                ("WriteOperationCount", ctypes.c_uint64),
                ("OtherOperationCount", ctypes.c_uint64),
                ("ReadTransferCount", ctypes.c_uint64),
                ("WriteTransferCount", ctypes.c_uint64),
                ("OtherTransferCount", ctypes.c_uint64),
            ]

        class JobObjectExtendedLimitInformation(ctypes.Structure):
            _fields_ = [
                ("BasicLimitInformation", JobObjectBasicLimitInformation),
                ("IoInfo", IoCounters),
                ("ProcessMemoryLimit", ctypes.c_size_t),
                ("JobMemoryLimit", ctypes.c_size_t),
                ("PeakProcessMemoryUsed", ctypes.c_size_t),
                ("PeakJobMemoryUsed", ctypes.c_size_t),
            ]

        self.extended_limit_type = JobObjectExtendedLimitInformation
        self.kernel32 = ctypes.WinDLL("kernel32", use_last_error=True)
        self.kernel32.CreateJobObjectW.argtypes = [ctypes.c_void_p, wintypes.LPCWSTR]
        self.kernel32.CreateJobObjectW.restype = wintypes.HANDLE
        self.kernel32.SetInformationJobObject.argtypes = [
            wintypes.HANDLE,
            ctypes.c_int,
            ctypes.c_void_p,
            wintypes.DWORD,
        ]
        self.kernel32.SetInformationJobObject.restype = wintypes.BOOL
        self.kernel32.OpenProcess.argtypes = [wintypes.DWORD, wintypes.BOOL, wintypes.DWORD]
        self.kernel32.OpenProcess.restype = wintypes.HANDLE
        self.kernel32.AssignProcessToJobObject.argtypes = [wintypes.HANDLE, wintypes.HANDLE]
        self.kernel32.AssignProcessToJobObject.restype = wintypes.BOOL
        self.kernel32.CloseHandle.argtypes = [wintypes.HANDLE]
        self.kernel32.CloseHandle.restype = wintypes.BOOL

    def create_kill_on_close_job(self) -> Any:
        handle = self.kernel32.CreateJobObjectW(None, None)
        if not handle:
            raise ctypes.WinError(ctypes.get_last_error())
        info = self.extended_limit_type()
        info.BasicLimitInformation.LimitFlags = JOB_OBJECT_LIMIT_KILL_ON_JOB_CLOSE
        if not self.kernel32.SetInformationJobObject(
            handle,
            JOB_OBJECT_EXTENDED_LIMIT_INFORMATION,
            ctypes.byref(info),
            ctypes.sizeof(info),
        ):
            error = ctypes.get_last_error()
            self.kernel32.CloseHandle(handle)
            raise ctypes.WinError(error)
        return handle

    def assign_process(self, job_handle: Any, pid: int) -> None:
        process_handle = self.kernel32.OpenProcess(PROCESS_TERMINATE | PROCESS_SET_QUOTA, False, pid)
        if not process_handle:
            raise ctypes.WinError(ctypes.get_last_error())
        try:
            if not self.kernel32.AssignProcessToJobObject(job_handle, process_handle):
                raise ctypes.WinError(ctypes.get_last_error())
        finally:
            self.kernel32.CloseHandle(process_handle)

    def close(self, handle: Any) -> None:
        if not self.kernel32.CloseHandle(handle):
            raise ctypes.WinError(ctypes.get_last_error())


class WindowsProcessTree:
    def __init__(self, pid: int, api: Any | None = None) -> None:
        self.api = api or WindowsJobApi()
        self.lock = threading.Lock()
        self.handle = self.api.create_kill_on_close_job()
        try:
            self.api.assign_process(self.handle, pid)
        except Exception:
            self.api.close(self.handle)
            self.handle = None
            raise

    def terminate(self) -> None:
        with self.lock:
            handle = self.handle
            if handle is None:
                return
            self.api.close(handle)
            self.handle = None


class CwdReporter:
    def __init__(self) -> None:
        self.pending = b""

    def feed(self, data: bytes) -> list[str]:
        combined = self.pending + data
        pending_start = combined.rfind(b"\x1b]7;")
        searchable = combined
        self.pending = b""
        if pending_start >= 0:
            tail = combined[pending_start:]
            if b"\x07" not in tail and b"\x1b\\" not in tail:
                searchable = combined[:pending_start]
                self.pending = tail[-8192:]

        values: list[str] = []
        for match in OSC7_PATTERN.finditer(searchable):
            raw = match.group(1).decode("utf-8", errors="replace")
            slash = raw.find("/")
            if slash < 0:
                continue
            path = unquote(raw[slash:])
            if re.match(r"^/[A-Za-z]:[\\/]", path):
                path = path[1:]
            if len(path) > 4096 or re.search(r"[\x00-\x1f\x7f]", path):
                continue
            if re.match(r"^[A-Za-z]:[\\/]", path) or path.startswith("/"):
                values.append(path)
        return values


class TerminalQueryResponder:
    def __init__(self) -> None:
        self.pending = b""

    def feed(self, data: bytes) -> list[bytes]:
        replies: list[bytes] = []
        queries = tuple(LOCAL_TERMINAL_QUERY_RESPONSES)
        for value in data:
            self.pending += bytes((value,))
            while self.pending and not any(query.startswith(self.pending) for query in queries):
                self.pending = self.pending[1:]
            reply = LOCAL_TERMINAL_QUERY_RESPONSES.get(self.pending)
            if reply is not None:
                replies.append(reply)
                self.pending = b""
        return replies


def load_config(path: str) -> dict[str, Any]:
    expanded = os.path.expanduser(path)
    if not os.path.isfile(expanded):
        return {}
    with open(expanded, "r", encoding="utf-8") as handle:
        value = json.load(handle)
    if not isinstance(value, dict):
        raise SystemExit(f"wmux-windows-agent: config must be a JSON object: {expanded}")
    return value


def config_string(config: dict[str, Any], key: str, fallback: str = "") -> str:
    value = config.get(key)
    return value if isinstance(value, str) else fallback


def config_int(config: dict[str, Any], key: str, fallback: int) -> int:
    value = config.get(key)
    if isinstance(value, int):
        return value
    if isinstance(value, str):
        try:
            return int(value)
        except ValueError:
            return fallback
    return fallback


def pywinpty_available() -> bool:
    if os.name != "nt":
        return False
    try:
        import winpty  # type: ignore

        return hasattr(winpty, "PtyProcess")
    except Exception:
        return False


def conpty_available() -> bool:
    return pywinpty_available()


def configured_backend(config: dict[str, Any]) -> str:
    value = config_string(config, "backend", BACKEND_CONPTY).strip().lower()
    if value in (BACKEND_STDIO, "legacy", "legacy-stdio"):
        return BACKEND_STDIO
    if value == "auto":
        return BACKEND_CONPTY if conpty_available() else BACKEND_STDIO
    return BACKEND_CONPTY


def helper_bundle_version(config: dict[str, Any]) -> str:
    helper_dir = os.path.expandvars(config_string(config, "helperDir"))
    version_path = os.path.join(helper_dir, "bundle-version.json") if helper_dir else ""
    if not version_path or not os.path.isfile(version_path):
        return ""
    try:
        with open(version_path, "r", encoding="utf-8") as handle:
            value = json.load(handle)
        return str(value.get("bundleVersion") or "") if isinstance(value, dict) else ""
    except Exception:
        return ""


def refresh_callback_state(payload: dict[str, Any]) -> None:
    payload_env = payload.get("env")
    if not isinstance(payload_env, dict):
        return
    values = {
        "url": payload_env.get("WMUX_URL"),
        "token": payload_env.get("WMUX_TOKEN"),
    }
    if not any(isinstance(value, str) and value.strip() for value in values.values()):
        return
    state_dir = os.path.expanduser("~/.wmux")
    os.makedirs(state_dir, mode=0o700, exist_ok=True)
    try:
        os.chmod(state_dir, 0o700)
    except OSError:
        pass
    for name, raw_value in values.items():
        if not isinstance(raw_value, str) or not raw_value.strip():
            continue
        path = os.path.join(state_dir, name)
        temporary = f"{path}.tmp-{os.getpid()}-{threading.get_ident()}"
        try:
            with open(temporary, "w", encoding="utf-8", newline="\n") as handle:
                handle.write(raw_value.strip())
                handle.write("\n")
            os.chmod(temporary, 0o600)
            os.replace(temporary, path)
        finally:
            try:
                os.unlink(temporary)
            except FileNotFoundError:
                pass


def stage_helper_bundle(config: dict[str, Any], payload: dict[str, Any]) -> None:
    # A create request also serves as an attach request for an existing durable
    # ConPTY session. Refresh callback state even when no helper files changed.
    refresh_callback_state(payload)
    bundle = payload.get("helperBundle")
    if not isinstance(bundle, dict) or not isinstance(bundle.get("files"), list):
        return
    helper_dir = os.path.expandvars(config_string(config, "helperDir"))
    if not helper_dir:
        return
    os.makedirs(helper_dir, exist_ok=True)
    staging = os.path.join(helper_dir, f".staging-agent-{os.getpid()}-{threading.get_ident()}")
    shutil.rmtree(staging, ignore_errors=True)
    os.makedirs(staging)
    try:
        staged_names: list[str] = []
        for entry in bundle["files"]:
            if not isinstance(entry, dict):
                raise ValueError("helper manifest entry must be an object")
            name = str(entry.get("name") or "")
            if not name or os.path.basename(name) != name:
                raise ValueError("helper manifest contains an invalid file name")
            data = base64.b64decode(str(entry.get("dataBase64") or ""), validate=True)
            expected = str(entry.get("sha256") or "").lower()
            if not expected or not hmac.compare_digest(hashlib.sha256(data).hexdigest(), expected):
                raise ValueError(f"helper hash verification failed for {name}")
            with open(os.path.join(staging, name), "wb") as handle:
                handle.write(data)
            staged_names.append(name)
        for name in staged_names:
            os.replace(os.path.join(staging, name), os.path.join(helper_dir, name))
        version = str(bundle.get("bundleVersion") or "")
        if version:
            version_path = os.path.join(helper_dir, "bundle-version.json")
            temporary_version = version_path + ".tmp"
            with open(temporary_version, "w", encoding="utf-8") as handle:
                json.dump({"bundleVersion": version}, handle)
                handle.write("\n")
            os.replace(temporary_version, version_path)
    finally:
        shutil.rmtree(staging, ignore_errors=True)


def is_private_bind_host(host: str) -> bool:
    if host in ("localhost", "::1") or host.startswith("127."):
        return True
    match = re.match(r"^(\d+)\.(\d+)\.(\d+)\.(\d+)$", host)
    if not match:
        return False
    first, second = int(match.group(1)), int(match.group(2))
    if first == 10 or first == 192 and second == 168:
        return True
    if first == 172 and 16 <= second <= 31:
        return True
    return first == 100 and 64 <= second <= 127


# Byte-identical copy of scripts/windows/wmux-cwd-prompt.ps1. The agent runs
# standalone on the Windows host, so it cannot read the wmux checkout; wmux's
# test/osc7.test.ts asserts this constant matches the canonical file.
CWD_PROMPT_PS1 = r"""function global:__wmuxFileUriPath([string]$PathValue) {
  $Normalized = $PathValue -replace '\\', '/'
  if ($Normalized -match '^[A-Za-z]:') {
    $Normalized = '/' + $Normalized
  }
  $Segments = $Normalized.Split([char]'/', [System.StringSplitOptions]::None)
  return (($Segments | ForEach-Object { [System.Uri]::EscapeDataString($_) }) -join '/')
}

function global:__wmuxEmitCwd {
  try {
    if ($PWD.Provider.Name -ne 'FileSystem') { return }
    $HostName = if ($env:COMPUTERNAME) { $env:COMPUTERNAME } else { 'windows' }
    $PathPart = __wmuxFileUriPath $PWD.ProviderPath
    [Console]::Write("$([char]27)]7;file://$HostName$PathPart$([char]7)")
  } catch {}
}

function global:prompt {
  __wmuxEmitCwd
  "PS $($executionContext.SessionState.Path.CurrentLocation)> "
}

try {
  Set-PSReadLineOption -PredictionSource None -ErrorAction SilentlyContinue
} catch {}
"""


def powershell_bootstrap(cwd: str) -> str:
    escaped_cwd = cwd.replace("'", "''")
    return (
        "\n$ErrorActionPreference = 'Continue'\n"
        + CWD_PROMPT_PS1
        + f"""
$AgentProfileHelper = if ($env:WMUX_HELPER_DIR) {{ Join-Path $env:WMUX_HELPER_DIR 'wmux-agent-profile.cmd' }} else {{ $null }}
if ($AgentProfileHelper -and (Test-Path -LiteralPath $AgentProfileHelper -PathType Leaf)) {{
  & $AgentProfileHelper apply --quiet
}}
if ('{escaped_cwd}') {{
  Set-Location -LiteralPath '{escaped_cwd}' -ErrorAction SilentlyContinue
}}
__wmuxEmitCwd
"""
    )


def powershell_command(shell: str, cwd: str) -> list[str]:
    executable = shell or "pwsh"
    return [
        executable,
        "-NoLogo",
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-NoExit",
        "-Command",
        powershell_bootstrap(cwd),
    ]


def session_environment(config: dict[str, Any], payload: dict[str, Any]) -> dict[str, str]:
    env = os.environ.copy()
    env.setdefault("TERM", "xterm-256color")
    env.setdefault("COLORTERM", "truecolor")
    helper_dir = os.path.expandvars(config_string(config, "helperDir"))
    if helper_dir:
        env["PATH"] = helper_dir + os.pathsep + env.get("PATH", "")
        env["WMUX_HELPER_DIR"] = helper_dir
    payload_env = payload.get("env")
    if isinstance(payload_env, dict):
        for key, value in payload_env.items():
            if isinstance(key, str) and isinstance(value, str):
                env[key] = value
    return env


def session_command(config: dict[str, Any], payload: dict[str, Any], cwd: str) -> list[str] | str:
    shell = str(payload.get("shell") or config_string(config, "shell", "pwsh"))
    lower_shell = os.path.basename(shell).lower()
    if lower_shell in ("pwsh", "pwsh.exe", "powershell", "powershell.exe"):
        return powershell_command(shell, cwd)
    return shell


class StdioBackend:
    name = BACKEND_STDIO

    def __init__(self, config: dict[str, Any], payload: dict[str, Any], cwd: str):
        command = session_command(config, payload, cwd)
        self.last_output_byte_was_cr = False
        self.process = subprocess.Popen(
            command,
            cwd=cwd if os.path.isdir(cwd) else None,
            env=session_environment(config, payload),
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            creationflags=getattr(subprocess, "CREATE_NEW_PROCESS_GROUP", 0),
        )
        try:
            self.process_tree = WindowsProcessTree(self.pid) if os.name == "nt" else None
        except Exception:
            self.process.terminate()
            raise

    @property
    def pid(self) -> int:
        return int(self.process.pid or 0)

    def write(self, data: bytes) -> None:
        if not self.process.stdin:
            return
        self.process.stdin.write(data.replace(b"\r", b"\n"))
        self.process.stdin.flush()

    def write_terminal_response(self, data: bytes) -> None:
        self.write(data)

    def resize(self, _cols: int, _rows: int) -> None:
        return

    def terminate(self) -> None:
        if self.process_tree:
            try:
                self.process_tree.terminate()
            except Exception:
                pass
        try:
            if os.name == "nt":
                self.process.send_signal(signal.CTRL_BREAK_EVENT)
                time.sleep(0.2)
            self.process.terminate()
        except Exception:
            pass

    def read_output(self, append: Any) -> int | None:
        try:
            while True:
                chunk = os.read(self.process.stdout.fileno(), 4096) if self.process.stdout else b""
                if not chunk:
                    break
                output, self.last_output_byte_was_cr = terminalize_stdio_output(
                    chunk,
                    self.last_output_byte_was_cr,
                )
                append(output)
            return self.process.poll()
        finally:
            if self.process_tree:
                try:
                    self.process_tree.terminate()
                except Exception:
                    pass


def terminalize_stdio_output(data: bytes, previous_ended_with_cr: bool = False) -> tuple[bytes, bool]:
    """Make pipe output obey terminal newline semantics.

    A PTY/ConPTY normally maps line feeds into a cursor-return plus line-feed.
    Plain stdout pipes from PowerShell often emit bare LF, which leaves a web
    terminal cursor at the previous column and makes the next prompt drift
    right. Preserve existing CRLF and only insert CR before bare LF.
    """
    output = bytearray()
    previous_was_cr = previous_ended_with_cr
    for byte in data:
        if byte == 0x0A and not previous_was_cr:
            output.append(0x0D)
        output.append(byte)
        previous_was_cr = byte == 0x0D
    return bytes(output), previous_was_cr


class ConptyBackend:
    name = BACKEND_CONPTY

    def __init__(self, config: dict[str, Any], payload: dict[str, Any], cwd: str, cols: int, rows: int):
        if not conpty_available():
            raise RuntimeError("pywinpty is required for the wmux ConPTY backend; run wmux-windows-setup install-deps")
        from winpty import Backend, PtyProcess  # type: ignore

        command = session_command(config, payload, cwd)
        self.process = PtyProcess.spawn(
            command,
            cwd=cwd if os.path.isdir(cwd) else None,
            env=session_environment(config, payload),
            dimensions=(max(1, int(rows)), max(2, int(cols))),
            backend=Backend.ConPTY,
        )
        try:
            self.process_tree = WindowsProcessTree(self.pid)
        except Exception:
            try:
                self.process.terminate(force=True)
                self.process.close(force=True)
            except Exception:
                pass
            raise
        self.lock = threading.Lock()
        self.closed = False
        self.query_responder = TerminalQueryResponder()
        self.locally_answered: set[bytes] = set()

    @property
    def pid(self) -> int:
        return int(self.process.pid or 0)

    def write(self, data: bytes) -> None:
        if self.closed or not data:
            return
        with self.lock:
            if self.closed:
                return
            self.process.write(data.decode("utf-8", errors="replace"))

    def write_terminal_response(self, data: bytes) -> None:
        if self.closed or not data:
            return
        with self.lock:
            if self.closed:
                return
            if data in self.locally_answered:
                return
            self.process.write(data.decode("utf-8", errors="replace"))

    def resize(self, cols: int, rows: int) -> None:
        if self.closed:
            return
        cols = max(2, int(cols))
        rows = max(1, int(rows))
        with self.lock:
            if self.closed:
                return
            self.process.setwinsize(rows, cols)

    def terminate(self) -> None:
        with self.lock:
            if self.closed:
                return
            try:
                self.process_tree.terminate()
            except Exception:
                pass
            try:
                self.process.terminate(force=True)
            except Exception:
                pass
            try:
                self.process.close(force=True)
            except Exception:
                pass
            self.closed = True

    def read_output(self, append: Any) -> int | None:
        try:
            while True:
                chunk = self.process.fileobj.recv(4096)
                if not chunk:
                    break
                chunk = chunk.replace(b"0011Ignore", b"")
                if chunk:
                    self._answer_terminal_queries(chunk)
                    append(chunk)
        except OSError:
            pass
        finally:
            exit_code = self._exit_code()
            self._close()
        return exit_code

    def _answer_terminal_queries(self, data: bytes) -> None:
        replies = self.query_responder.feed(data)
        if not replies:
            return
        with self.lock:
            if self.closed:
                return
            for reply in replies:
                self.locally_answered.add(reply)
                self.process.write(reply.decode("ascii"))

    def _exit_code(self) -> int | None:
        try:
            if self.process.isalive():
                return None
            value = self.process.exitstatus
            return int(value) if value is not None else None
        except Exception:
            return None

    def _close(self) -> None:
        with self.lock:
            if self.closed:
                return
            try:
                self.process_tree.terminate()
            except Exception:
                pass
            try:
                self.process.close(force=True)
            except Exception:
                pass
            self.closed = True


class Session:
    def __init__(
        self,
        session_id: str,
        config: dict[str, Any],
        payload: dict[str, Any],
        on_exit: Callable[[], None] | None = None,
    ):
        self.id = session_id
        self.config = config
        self.cwd = str(payload.get("cwd") or config_string(config, "cwd") or os.path.expanduser("~"))
        self.max_replay = max(65536, config_int(config, "maxReplayBytes", DEFAULT_REPLAY_BYTES))
        self.buffer = bytearray()
        self.base = 0
        self.condition = threading.Condition()
        self.cols = max(2, int(payload.get("cols") or 80))
        self.rows = max(1, int(payload.get("rows") or 24))
        self.resize_events: list[dict[str, int]] = [{"cursor": 0, "cols": self.cols, "rows": self.rows}]
        self.cwd_reporter = CwdReporter()
        self.exited = False
        self.exit_code: int | None = None
        self.on_exit = on_exit
        self.backend = self._create_backend(payload)
        self.reader = threading.Thread(target=self._read_output, name=f"wmux-agent-reader-{session_id}", daemon=True)
        self.reader.start()

    @property
    def cursor(self) -> int:
        return self.base + len(self.buffer)

    @property
    def pid(self) -> int:
        return self.backend.pid

    def snapshot(self) -> dict[str, Any]:
        return {
            "id": self.id,
            "pid": self.pid,
            "backend": self.backend.name,
            "status": "exited" if self.exited else "running",
            "exitCode": self.exit_code,
            "cwd": self.cwd,
            "base": self.base,
            "cursor": self.cursor,
            "cols": self.cols,
            "rows": self.rows,
        }

    def write(self, data: bytes, terminal_response: bool = False) -> None:
        if self.exited:
            return
        if terminal_response:
            self.backend.write_terminal_response(data)
        else:
            self.backend.write(data)

    def resize(self, cols: int, rows: int) -> None:
        if self.exited:
            return
        cols = max(2, int(cols))
        rows = max(1, int(rows))
        with self.condition:
            if cols == self.cols and rows == self.rows:
                return
            # Keep output appends behind this boundary so replay can apply the
            # exact geometry that was active for every byte in the buffer.
            self.backend.resize(cols, rows)
            self.cols = cols
            self.rows = rows
            event = {"cursor": self.cursor, "cols": cols, "rows": rows}
            if self.resize_events and self.resize_events[-1]["cursor"] == event["cursor"]:
                self.resize_events[-1] = event
            else:
                self.resize_events.append(event)
            self.condition.notify_all()

    def terminate(self) -> None:
        if self.exited:
            return
        self.backend.terminate()

    def read_from(self, cursor: int, timeout_ms: int) -> dict[str, Any]:
        deadline = time.monotonic() + max(0, timeout_ms) / 1000
        with self.condition:
            while cursor >= self.cursor and not self.exited:
                remaining = deadline - time.monotonic()
                if remaining <= 0:
                    break
                self.condition.wait(remaining)
            cursor = max(cursor, self.base)
            offset = cursor - self.base
            data = bytes(self.buffer[offset:])
            end_cursor = self.cursor
            geometry = self.resize_events[0]
            for event in self.resize_events:
                if event["cursor"] > cursor:
                    break
                geometry = event
            return {
                "base": self.base,
                "startCursor": cursor,
                "cursor": end_cursor,
                "cols": geometry["cols"],
                "rows": geometry["rows"],
                "resizes": [event for event in self.resize_events if cursor < event["cursor"] <= end_cursor],
                "dataBase64": base64.b64encode(data).decode("ascii") if data else "",
                "exited": self.exited,
                "exitCode": self.exit_code,
                "cwd": self.cwd,
            }

    def _create_backend(self, payload: dict[str, Any]) -> StdioBackend | ConptyBackend:
        backend = configured_backend(self.config)
        if backend == BACKEND_STDIO:
            return StdioBackend(self.config, payload, self.cwd)
        return ConptyBackend(self.config, payload, self.cwd, self.cols, self.rows)

    def _read_output(self) -> None:
        try:
            self.exit_code = self.backend.read_output(self._append)
        except Exception as error:
            self._append(f"\r\n[wmux-agent] backend read failed: {error}\r\n".encode("utf-8", errors="replace"))
            self.exit_code = None
        finally:
            self.exited = True
            self._append(f"\r\n[wmux-agent] process exited with code {self.exit_code}\r\n".encode("utf-8"))
            with self.condition:
                self.condition.notify_all()
            if self.on_exit:
                self.on_exit()

    def _append(self, data: bytes) -> None:
        reported_cwds = self.cwd_reporter.feed(data)
        if reported_cwds:
            self.cwd = reported_cwds[-1]
        with self.condition:
            self.buffer.extend(data)
            if len(self.buffer) > self.max_replay:
                overflow = len(self.buffer) - self.max_replay
                del self.buffer[:overflow]
                self.base += overflow
                prior = [event for event in self.resize_events if event["cursor"] <= self.base]
                later = [event for event in self.resize_events if event["cursor"] > self.base]
                self.resize_events = ([prior[-1]] if prior else []) + later
            self.condition.notify_all()


class AgentState:
    def __init__(self, config: dict[str, Any]):
        self.config = config
        self.backend = configured_backend(config)
        self.sessions: dict[str, Session] = {}
        self.lock = threading.Lock()
        self.draining = False
        self.update_pending = False
        self.restart_when_idle = False
        self.restart_requested = False
        self.restart_scheduled = False
        self.shutdown_callback: Callable[[], None] | None = None

    def get_or_create(self, session_id: str, payload: dict[str, Any]) -> Session:
        with self.lock:
            existing = self.sessions.get(session_id)
            if existing and not existing.exited:
                return existing
            if self.draining:
                raise AgentDrainingError("agent is draining; close existing panes or cancel the drain before creating a new pane")
            session = Session(session_id, self.config, payload, self._session_exited)
            self.sessions[session_id] = session
            return session

    def get(self, session_id: str) -> Session | None:
        with self.lock:
            return self.sessions.get(session_id)

    def delete(self, session_id: str) -> bool:
        with self.lock:
            session = self.sessions.pop(session_id, None)
        if not session:
            return False
        session.terminate()
        self._schedule_restart_if_idle()
        return True

    def list_sessions(self) -> list[dict[str, Any]]:
        with self.lock:
            return [session.snapshot() for session in self.sessions.values()]

    def health(self) -> dict[str, Any]:
        with self.lock:
            active_sessions = sum(1 for session in self.sessions.values() if not session.exited)
            return {
                "sessions": len(self.sessions),
                "activeSessions": active_sessions,
                "draining": self.draining,
                "updatePending": self.update_pending,
                "restartWhenIdle": self.restart_when_idle,
            }

    def begin_drain(self, restart_when_idle: bool, allow_new_sessions: bool = False) -> dict[str, Any]:
        with self.lock:
            self.update_pending = restart_when_idle and allow_new_sessions
            self.draining = not self.update_pending
            self.restart_when_idle = restart_when_idle
        self._schedule_restart_if_idle()
        return self.health()

    def cancel_drain(self) -> dict[str, Any]:
        with self.lock:
            if not self.restart_requested:
                self.draining = False
                self.update_pending = False
                self.restart_when_idle = False
        return self.health()

    def set_shutdown_callback(self, callback: Callable[[], None]) -> None:
        self.shutdown_callback = callback

    def _session_exited(self) -> None:
        self._schedule_restart_if_idle()

    def _schedule_restart_if_idle(self) -> None:
        with self.lock:
            active_sessions = any(not session.exited for session in self.sessions.values())
            if (
                active_sessions
                or not (self.draining or self.update_pending)
                or not self.restart_when_idle
                or self.restart_requested
                or self.restart_scheduled
            ):
                return
            self.restart_scheduled = True
        timer = threading.Timer(0.25, self._restart_if_still_idle)
        timer.daemon = True
        timer.start()

    def _restart_if_still_idle(self) -> None:
        with self.lock:
            self.restart_scheduled = False
            active_sessions = any(not session.exited for session in self.sessions.values())
            if active_sessions or not (self.draining or self.update_pending) or not self.restart_when_idle or self.restart_requested:
                return
            # Close the create/restart race atomically. Pending updates accept
            # panes while any session is active, then become a hard drain only
            # for the brief interval between the final close and process exit.
            self.draining = True
            self.update_pending = False
            self.restart_requested = True
            callback = self.shutdown_callback
        if callback:
            callback()


class Handler(BaseHTTPRequestHandler):
    state: AgentState

    def log_message(self, message: str, *args: Any) -> None:
        print(f"wmux-windows-agent: {self.address_string()} {message % args}", file=sys.stderr)

    def authorized(self) -> bool:
        expected = str(self.state.config.get("token") or os.environ.get("WMUX_AGENT_TOKEN") or "")
        if not expected:
            return True
        header = self.headers.get("authorization") or ""
        match = re.match(r"^Bearer\s+(.+)$", header.strip(), re.IGNORECASE)
        presented = match.group(1).strip() if match else ""
        # Length-independent compare_digest guards against timing discovery.
        return bool(presented) and hmac.compare_digest(presented, expected)

    def do_GET(self) -> None:
        parsed = urlparse(self.path)
        parts = [unquote(part) for part in parsed.path.strip("/").split("/") if part]
        if parts == ["health"]:
            lifecycle = self.state.health()
            self.send_json(
                {
                    "ok": True,
                    # `version` remains as a transition alias for wmux servers
                    # that predate the structured release/protocol fields.
                    "version": RELEASE_VERSION,
                    "releaseVersion": RELEASE_VERSION,
                    "protocolVersion": PROTOCOL_VERSION,
                    "capabilities": ["paste-images-v1"],
                    "machine": config_string(self.state.config, "machine", "windows"),
                    "pid": os.getpid(),
                    **lifecycle,
                    "backend": self.state.backend,
                    "processTree": "windows-job",
                    "helperBundleVersion": helper_bundle_version(self.state.config),
                    "conptyAvailable": conpty_available(),
                    "pywinptyAvailable": pywinpty_available(),
                }
            )
            return
        if not self.authorized():
            self.send_json({"error": "unauthorized"}, status=401)
            return
        if parts == ["sessions"]:
            self.send_json({"sessions": self.state.list_sessions()})
            return
        if parts == ["drain"]:
            self.send_json(self.state.health())
            return
        if len(parts) == 3 and parts[0] == "sessions" and parts[2] == "output":
            session = self.require_session(parts[1])
            if not session:
                return
            query = parse_qs(parsed.query)
            cursor = int(query.get("cursor", ["0"])[0] or "0")
            timeout_ms = min(30000, int(query.get("timeoutMs", ["15000"])[0] or "15000"))
            self.send_json(session.read_from(cursor, timeout_ms))
            return
        self.send_json({"error": "not_found"}, status=404)

    def do_POST(self) -> None:
        if not self.authorized():
            self.send_json({"error": "unauthorized"}, status=401)
            return
        parsed = urlparse(self.path)
        parts = [unquote(part) for part in parsed.path.strip("/").split("/") if part]
        if parts == ["drain"]:
            body = self.read_json()
            self.send_json(self.state.begin_drain(
                body.get("restartWhenIdle") is not False,
                body.get("allowNewSessions") is True,
            ))
            return
        if len(parts) == 2 and parts[0] == "sessions":
            try:
                payload = self.read_json()
                stage_helper_bundle(self.state.config, payload)
                session = self.state.get_or_create(parts[1], payload)
            except AgentDrainingError as error:
                self.send_json({"error": "agent_draining", "message": str(error)}, status=503)
                return
            except Exception as error:
                self.send_json({"error": "session_start_failed", "message": str(error)}, status=500)
                return
            self.send_json(session.snapshot())
            return
        if len(parts) == 3 and parts[0] == "sessions" and parts[2] == "input":
            session = self.require_session(parts[1])
            if not session:
                return
            body = self.read_json()
            data = base64.b64decode(str(body.get("dataBase64") or ""))
            session.write(data, terminal_response=body.get("terminalResponse") is True)
            self.send_json({"ok": True})
            return
        if len(parts) == 3 and parts[0] == "sessions" and parts[2] == "resize":
            session = self.require_session(parts[1])
            if not session:
                return
            body = self.read_json()
            session.resize(int(body.get("cols") or 80), int(body.get("rows") or 24))
            self.send_json({"ok": True})
            return
        if len(parts) == 4 and parts[0] == "sessions" and parts[2] == "paste-images":
            session = self.require_session(parts[1])
            if not session or session.exited:
                if session:
                    self.send_json({"error": "session_exited"}, status=409)
                return
            query = parse_qs(parsed.query)
            extension = str(query.get("extension", [""])[0]).lower()
            content_type = (self.headers.get("content-type") or "").split(";", 1)[0].strip().lower()
            if content_type != "application/octet-stream":
                self.send_json({"error": "invalid_content_type"}, status=415)
                return
            length_header = self.headers.get("content-length")
            try:
                length = int(length_header or "")
            except ValueError:
                length = -1
            if length <= 0 or length > MAX_PASTE_IMAGE_BYTES:
                self.send_json({"error": "invalid_content_length"}, status=413 if length > MAX_PASTE_IMAGE_BYTES else 411)
                return
            data = self.rfile.read(length)
            if len(data) != length:
                self.send_json({"error": "incomplete_body"}, status=400)
                return
            if self.state.get(parts[1]) is not session or session.exited:
                self.send_json({"error": "session_exited"}, status=409)
                return
            try:
                result = stage_paste_image(self.state.config, parts[1], parts[3], extension, data)
            except (OSError, ValueError):
                self.send_json({"error": "paste_image_stage_failed"}, status=400)
                return
            self.send_json(result, status=201)
            return
        self.send_json({"error": "not_found"}, status=404)

    def do_DELETE(self) -> None:
        if not self.authorized():
            self.send_json({"error": "unauthorized"}, status=401)
            return
        parsed = urlparse(self.path)
        parts = [unquote(part) for part in parsed.path.strip("/").split("/") if part]
        if parts == ["drain"]:
            self.send_json(self.state.cancel_drain())
            return
        if len(parts) == 2 and parts[0] == "sessions":
            removed = self.state.delete(parts[1])
            delete_session_paste_images(self.state.config, parts[1])
            self.send_json({"removed": removed})
            return
        if len(parts) == 4 and parts[0] == "sessions" and parts[2] == "paste-images":
            self.send_json({"removed": delete_paste_image(self.state.config, parts[1], parts[3])})
            return
        self.send_json({"error": "not_found"}, status=404)

    def read_json(self) -> dict[str, Any]:
        length = int(self.headers.get("content-length") or "0")
        if length <= 0:
            return {}
        raw = self.rfile.read(min(length, 2 * 1024 * 1024)).decode("utf-8")
        value = json.loads(raw)
        return value if isinstance(value, dict) else {}

    def require_session(self, session_id: str) -> Session | None:
        session = self.state.get(session_id)
        if session:
            return session
        self.send_json({"error": "unknown_session"}, status=404)
        return None

    def send_json(self, payload: Any, status: int = 200) -> None:
        data = json.dumps(payload, separators=(",", ":")).encode("utf-8")
        self.send_response(status)
        self.send_header("content-type", "application/json")
        self.send_header("content-length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)


def main() -> int:
    parser = argparse.ArgumentParser(prog="wmux-windows-agent")
    parser.add_argument("--config", default=os.environ.get("WMUX_WINDOWS_AGENT_CONFIG", "~/.wmux/windows-agent.json"))
    parser.add_argument("--host", default="")
    parser.add_argument("--port", type=int, default=0)
    parser.add_argument("--allow-public-bind", action="store_true")
    args = parser.parse_args()
    config = load_config(args.config)
    host = args.host or config_string(config, "host", "127.0.0.1")
    port = args.port or config_int(config, "port", 3481)
    if not args.allow_public_bind and not is_private_bind_host(host):
        raise SystemExit(f"wmux-windows-agent: refusing to bind non-private host {host}")
    Handler.state = AgentState(config)
    server = ThreadingHTTPServer((host, port), Handler)
    Handler.state.set_shutdown_callback(lambda: threading.Thread(target=server.shutdown, daemon=True).start())
    print(f"wmux-windows-agent: listening on http://{host}:{port}", file=sys.stderr)
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        return 0
    finally:
        server.server_close()
    return AGENT_RESTART_EXIT_CODE if Handler.state.restart_requested else 0


if __name__ == "__main__":
    raise SystemExit(main())
