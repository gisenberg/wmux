#!/usr/bin/env python3
import argparse
import json
import os
import re
import sys
import urllib.request


def _wmux_file(path):
    try:
        with open(path, "r", encoding="utf-8") as handle:
            return handle.read().strip()
    except OSError:
        return ""


def _wmux_env(name):
    return os.environ.get(name, "").strip()


def _wmux_scoped_token():
    env_configured = "WMUX_HELPER_TOKEN" in os.environ
    env_token = _wmux_env("WMUX_HELPER_TOKEN")
    if env_configured and not re.fullmatch(r"[A-Za-z0-9_-]{32,256}", env_token):
        raise SystemExit("wmux-agent-event: configured helper token is empty or malformed")
    path_configured = "WMUX_HELPER_TOKEN_PATH" in os.environ
    path_value = os.environ.get("WMUX_HELPER_TOKEN_PATH", "").strip()
    if path_configured and not path_value:
        raise SystemExit("wmux-agent-event: configured helper token path is empty")
    token_path = path_value if path_configured else os.path.expanduser("~/.wmux/helper-token")
    if path_configured or os.path.exists(token_path):
        token = _wmux_file(token_path)
        if not re.fullmatch(r"[A-Za-z0-9_-]{32,256}", token):
            raise SystemExit("wmux-agent-event: configured helper token file is unreadable or malformed")
        return token
    return env_token if env_configured else None


def _wmux_token():
    # Durable processes retain token environment across restarts, while wmux refreshes
    # this owner-only file on every reattach.
    token = _wmux_scoped_token()
    if token is not None:
        return token
    if _wmux_env("WMUX_BROWSER_AUTH_MODE") == "login-only":
        return ""
    token = _wmux_file(os.environ.get("WMUX_TOKEN_PATH") or os.path.expanduser("~/.wmux/token"))
    return token or _wmux_env("WMUX_TOKEN")


def _wmux_url():
    # Durable processes retain their environment across restarts, while wmux
    # refreshes this owner-only file on every reattach.
    return (
        _wmux_file(os.path.expanduser("~/.wmux/url"))
        or _wmux_env("WMUX_HELPER_URL")
        or _wmux_env("WMUX_PUBLIC_URL")
        or _wmux_env("WMUX_URL")
        or "http://127.0.0.1:3478"
    )


def _wmux_auth_headers():
    token = _wmux_token()
    return {"authorization": "Bearer " + token} if token else {}


_NOISE_BLOCK_TAGS = (
    "system-reminder",
    "command-name",
    "command-message",
    "command-args",
    "local-command-stdout",
    "local-command-stderr",
    "local-command-caveat",
    "function_calls",
    "function_results",
)


def strip_markup(value):
    # Drop Claude Code's injected XML-ish wrappers (and their content) plus any
    # stray tags so agent-derived titles/summaries stay human-readable.
    for tag in _NOISE_BLOCK_TAGS:
        value = re.sub(rf"<{tag}(?:\s[^>]*)?>.*?</{tag}>", " ", value, flags=re.I | re.S)
    return re.sub(r"</?[a-zA-Z][^>]*>", " ", value)


def clean_text(value, limit):
    value = strip_markup(value or "")
    value = re.sub(r"\s+", " ", value).strip()
    return value[:limit]


def clean_message(value, limit=12000):
    value = strip_markup(value or "").replace("\r\n", "\n").replace("\r", "\n")
    value = re.sub(r"[\x00-\x08\x0b\x0c\x0e-\x1f\x7f]", "", value)
    value = re.sub(r"[ \t]+\n", "\n", value)
    value = re.sub(r"\n{4,}", "\n\n\n", value).strip()
    return value[:limit]


def text_from_content(content):
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        parts = []
        for item in content:
            if isinstance(item, dict) and item.get("type") == "text":
                parts.append(str(item.get("text") or ""))
            elif isinstance(item, dict) and item.get("type") in ("input_text", "output_text"):
                parts.append(str(item.get("text") or ""))
            elif isinstance(item, str):
                parts.append(item)
        return "\n".join(parts)
    if isinstance(content, dict):
        if isinstance(content.get("text"), str):
            return content["text"]
        if isinstance(content.get("content"), (str, list, dict)):
            return text_from_content(content.get("content"))
    return ""


def title_from_prompt(prompt):
    prompt = clean_text(prompt, 300)
    prompt = re.sub(r"^(please|can you|could you|let'?s|we need to|i want to)\s+", "", prompt, flags=re.I)
    prompt = prompt.rstrip(".?!:; ")
    if not prompt:
        return ""
    words = prompt.split()
    return clean_text(" ".join(words[:8]), 50)


def summary_from_output(output):
    output = clean_text(output, 600)
    if not output:
        return ""
    first = re.split(r"(?<=[.!?])\s+|\n+", output, maxsplit=1)[0]
    return clean_text(first, 120)


def read_hook_input():
    raw = os.environ.get("HOOK_INPUT", "")
    if not raw and not sys.stdin.isatty():
        raw = sys.stdin.read()
    if not raw:
        return {}
    try:
        return json.loads(raw)
    except json.JSONDecodeError:
        return {}


def transcript_summary(path):
    if not path or not os.path.isfile(path):
        return "", "", ""
    last_user = ""
    last_assistant = ""
    try:
        with open(path, "r", encoding="utf-8", errors="replace") as handle:
            for line in handle:
                try:
                    entry = json.loads(line)
                except json.JSONDecodeError:
                    continue
                message = entry.get("message") if isinstance(entry.get("message"), dict) else entry
                if isinstance(entry.get("item"), dict):
                    message = entry["item"]
                if isinstance(entry.get("payload"), dict):
                    message = entry["payload"]
                role = message.get("role")
                if not role and message.get("type") == "user_message":
                    role = "user"
                if not role and message.get("type") in ("assistant_message", "agent_message"):
                    role = "assistant"
                text = text_from_content(message.get("content"))
                if not text:
                    text = text_from_content(message.get("text"))
                if not text:
                    text = text_from_content(message.get("message"))
                if role == "user" and text:
                    last_user = text
                if role == "assistant" and text:
                    last_assistant = text
    except OSError:
        return "", "", ""
    return title_from_prompt(last_user), summary_from_output(last_assistant), clean_message(last_assistant)


def post_json(url, payload):
    request = urllib.request.Request(
        url.rstrip("/") + "/api/agent-events",
        data=json.dumps(payload).encode("utf-8"),
        headers={"content-type": "application/json", **_wmux_auth_headers()},
        method="POST",
    )
    with urllib.request.urlopen(request, timeout=15):
        pass


def main():
    parser = argparse.ArgumentParser(prog="wmux-agent-event")
    parser.add_argument("--url", default=_wmux_url())
    parser.add_argument("--agent", default=os.environ.get("WMUX_AGENT_NAME", "agent"))
    parser.add_argument("--status", default="completed")
    parser.add_argument("--title", default="")
    parser.add_argument("--summary", default="")
    parser.add_argument("--message", default="")
    parser.add_argument("--body", default="")
    parser.add_argument("--pane", default=os.environ.get("WMUX_PANE_ID", ""))
    parser.add_argument("--workspace", default=os.environ.get("WMUX_WORKSPACE_ID", ""))
    parser.add_argument("--tab", default=os.environ.get("WMUX_TAB_ID", ""))
    parser.add_argument("--transcript", default="")
    parser.add_argument("--claude-hook", action="store_true")
    parser.add_argument("--codex-hook", action="store_true")
    parser.add_argument("--opencode-hook", action="store_true")
    parser.add_argument("--force", action="store_true")
    args = parser.parse_args()

    if not args.force and not args.pane and not args.workspace:
        return 0

    hook_input = read_hook_input() if args.claude_hook or args.codex_hook or args.opencode_hook else {}
    transcript = args.transcript or hook_input.get("transcript_path") or hook_input.get("agent_transcript_path") or ""
    transcript_title, transcript_summary_text, transcript_message = transcript_summary(transcript)

    hook_event = str(hook_input.get("hook_event_name") or "")
    hook_title = clean_text(hook_input.get("title") if isinstance(hook_input.get("title"), str) else "", 80)
    prompt_title = title_from_prompt(hook_input.get("prompt") or "")
    hook_summary = summary_from_output(hook_input.get("last_assistant_message") or "")
    hook_message = clean_message(hook_input.get("last_assistant_message") or "")
    title = args.title or hook_title or prompt_title or transcript_title
    summary = args.summary or args.body or hook_summary or transcript_summary_text
    message = clean_message(args.message) or hook_message or transcript_message
    status = args.status
    if args.claude_hook:
        if hook_event == "UserPromptSubmit":
            status = "running"
            summary = "claude running"
            message = ""
        elif hook_event == "Notification":
            status = "updated"
            summary = clean_text(hook_input.get("message") or "claude notification", 500)
            message = ""
        elif hook_event:
            status = "completed"
            summary = summary or "claude completed"
        else:
            status = "completed"
    if args.codex_hook:
        if hook_event == "UserPromptSubmit":
            status = "running"
            summary = "codex running"
            message = ""
        elif hook_event:
            status = "completed"
            summary = summary or "codex completed"
    if args.opencode_hook:
        if hook_event == "UserPromptSubmit":
            status = "running"
            summary = "opencode running"
            message = ""
        elif hook_event == "Question":
            status = "waiting"
            summary = "opencode waiting for input"
            message = ""
        elif hook_event == "Resume":
            status = "running"
            summary = "opencode running"
            message = ""
        elif hook_event == "Error":
            status = "failed"
            summary = summary or "opencode failed"
        elif hook_event:
            status = "completed"
            summary = summary or "opencode completed"

    payload = {
        "agent": clean_text(args.agent, 50),
        "status": clean_text(status, 50),
        "title": clean_text(title, 80),
        "summary": clean_text(summary, 500),
        "body": clean_text(args.body, 500),
    }
    if message:
        payload["message"] = message
    if args.pane:
        payload["paneId"] = args.pane
    if args.workspace:
        payload["workspaceId"] = args.workspace
    if args.tab:
        payload["tabId"] = args.tab

    # Event delivery is telemetry; a down/unauthenticated server must never
    # fail the agent hook that invoked us (Claude/Codex surface non-zero hook
    # exits as errors and may block the prompt).
    try:
        post_json(args.url, payload)
    except Exception as error:  # noqa: BLE001
        print(f"wmux-agent-event: delivery failed: {error}", file=sys.stderr)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
