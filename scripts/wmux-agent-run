#!/usr/bin/env python3
"""Run a delegated request, or supervise an interactive TUI, from Base64 JSON."""
import base64
import json
import os
import re
import selectors
import shutil
import signal
import subprocess
import sys
import tempfile
import time

MAX_LINE = 1_100_000
MAX_PROMPT = 128 * 1024
MAX_TEXT = 64_000
TERMINATION_GRACE = 2.0
HELP_PROBE_TIMEOUT = 5.0
MAX_HELP_OUTPUT = 256 * 1024
MAX_BLANK_REQUEST_LINES = 8
RUNTIMES = {"opencode", "codex", "claude"}
SANDBOX_MODES = {"read-only", "workspace-write", "danger-full-access"}
RESULT_FORMATS = {"outcome-v1"}
OUTCOME_SCHEMA = {
    "type": "object",
    "properties": {
        "outcome": {"type": "string", "enum": ["completed", "blocked", "failed"]},
        "summary": {"type": "string"},
    },
    "required": ["outcome", "summary"],
    "additionalProperties": False,
}


def bounded(value):
    if not isinstance(value, str):
        return ""
    encoded = value.encode("utf-8")
    if len(encoded) <= MAX_TEXT:
        return value
    return encoded[:MAX_TEXT].decode("utf-8", errors="ignore")


def append_bounded(current, value):
    return bounded((current + "\n" if current else "") + value)


def emit(kind, value):
    encoded = base64.b64encode(json.dumps(value, separators=(",", ":")).encode()).decode()
    print("%s %s" % (kind, encoded), flush=True)


def fail(run_id, message, code=2):
    emit("WMUX_AGENT_RESULT", {"runId": run_id, "ok": False, "error": bounded(message)})
    print("WMUX_AGENT_DONE %s %d" % (run_id, code), flush=True)
    return code


def read_request_line():
    for _attempt in range(MAX_BLANK_REQUEST_LINES + 1):
        line = sys.stdin.buffer.readline(MAX_LINE + 1)
        if len(line) > MAX_LINE:
            raise ValueError("request is too large")
        if line.strip():
            return line
        if not line:
            break
    raise ValueError("request must be Base64 JSON")


def request_from_stdin(marker="WMUX_AGENT_READY"):
    tty_state = None
    if sys.stdin.isatty() and os.name == "nt":
        import msvcrt

        print(marker, flush=True)
        while True:
            characters = []
            while True:
                character = msvcrt.getwch()
                if character in {"\r", "\n"}:
                    break
                if character == "\x03":
                    raise KeyboardInterrupt
                if character in {"\x00", "\xe0"}:
                    msvcrt.getwch()
                    continue
                characters.append(character)
                if len("".join(characters).encode("utf-8")) > MAX_LINE:
                    raise ValueError("request is too large")
            if characters:
                print(flush=True)
                line = "".join(characters).encode("utf-8")
                break
    elif sys.stdin.isatty():
        import termios

        tty_state = termios.tcgetattr(sys.stdin.fileno())
        quiet = termios.tcgetattr(sys.stdin.fileno())
        quiet[3] &= ~termios.ECHO
        termios.tcsetattr(sys.stdin.fileno(), termios.TCSADRAIN, quiet)
        try:
            print(marker, flush=True)
            line = read_request_line()
        finally:
            termios.tcsetattr(sys.stdin.fileno(), termios.TCSADRAIN, tty_state)
            print(flush=True)
    else:
        print(marker, flush=True)
        line = read_request_line()
    try:
        request = json.loads(base64.b64decode(line.strip(), validate=True))
    except Exception as error:
        raise ValueError("request must be Base64 JSON") from error
    if not isinstance(request, dict):
        raise ValueError("request must be an object")
    return request


def validate(request, tui=False):
    run_id, prompt, directory = (request.get(key) for key in ("runId", "prompt", "directory"))
    runtime = request.get("runtime") or os.environ.get("WMUX_AGENT_RUNTIME_DEFAULT")
    valid_id = isinstance(run_id, str) and 0 < len(run_id) <= 128 and all(
        char in "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789._-" for char in run_id
    )
    if not valid_id:
        raise ValueError("invalid runId")
    if runtime not in RUNTIMES:
        raise ValueError("runtime must be opencode, codex, or claude")
    if not tui and (not isinstance(prompt, str) or not prompt or len(prompt.encode()) > MAX_PROMPT):
        raise ValueError("invalid prompt")
    if not isinstance(directory, str) or len(directory) > 4096 or "\x00" in directory:
        raise ValueError("invalid directory")
    if tui and not directory.startswith("/"):
        raise ValueError("invalid directory")
    directory = os.path.abspath(os.path.expanduser(directory))
    if not os.path.isdir(directory):
        raise ValueError("directory does not exist")
    for key in ("agent", "model", "title"):
        if key in request and (not isinstance(request[key], str) or len(request[key]) > 512 or "\x00" in request[key]):
            raise ValueError("invalid %s" % key)
    for key in ("unattended", "writeAccess"):
        if key in request and not isinstance(request[key], bool):
            raise ValueError("invalid %s" % key)
    sandbox_mode = request.get("sandboxMode")
    if sandbox_mode is not None and sandbox_mode not in SANDBOX_MODES:
        raise ValueError("sandboxMode must be read-only, workspace-write, or danger-full-access")
    result_format = request.get("resultFormat")
    if result_format is not None and result_format not in RESULT_FORMATS:
        raise ValueError("resultFormat must be outcome-v1")
    if result_format and runtime != "codex":
        raise ValueError("structured outcomes currently require the Codex runtime")
    if tui:
        if "prompt" in request:
            raise ValueError("interactive request must not contain prompt")
        allowed = {"runId", "runtime", "directory", "model", "agent"}
        unknown = sorted(set(request) - allowed)
        if unknown:
            raise ValueError("interactive request contains forbidden key: %s" % unknown[0])
        if "agent" in request and runtime != "opencode":
            raise ValueError("interactive agent is only valid for opencode")
    return run_id, runtime, prompt, directory


def tui_command_for(request, runtime):
    executable = shutil.which(runtime)
    if not executable:
        raise FileNotFoundError("%s executable not found" % runtime)
    # PATH may contain relative entries. Pin what was selected before changing
    # cwd so a repository-local executable cannot replace it at launch time.
    executable = os.path.realpath(os.path.abspath(executable))
    if not os.path.isabs(executable):
        raise ValueError("%s executable did not resolve to an absolute path" % runtime)
    model = request.get("model")
    argv = [executable]
    if runtime == "opencode" and request.get("agent"):
        argv.extend(["--agent", request["agent"]])
    if model:
        argv.extend(["--model", model])
    return argv


def tui_main(expected_run_id):
    run_id = expected_run_id or "unknown"
    try:
        request = request_from_stdin("WMUX_AGENT_TUI_READY %s" % run_id)
        candidate = request.get("runId")
        if not expected_run_id and isinstance(candidate, str) and re.fullmatch(r"[A-Za-z0-9._-]{1,128}", candidate):
            run_id = candidate
        request_run_id, runtime, _prompt, directory = validate(request, tui=True)
        if expected_run_id and request_run_id != expected_run_id:
            raise ValueError("runId does not match TUI launch marker")
        run_id = request_run_id
        argv = tui_command_for(request, runtime)
    except FileNotFoundError as error:
        return fail(run_id, str(error), 127)
    except (OSError, ValueError) as error:
        return fail(run_id, str(error))

    ack = "WMUX_AGENT_TUI_ACK %s" % run_id
    try:
        received = control_line("WMUX_AGENT_TUI_LAUNCH %s" % run_id)
        if received != ack:
            code = fail(run_id, "invalid interactive controller acknowledgement")
            quarantine_tui(run_id)
            return code
        env = os.environ.copy()
        env["WMUX_INTERACTIVE_TUI"] = "1"
        code = supervise_tui(argv, directory, env)
    except OSError as error:
        code = fail(run_id, str(error), 127)
        quarantine_tui(run_id)
        return code
    print("WMUX_AGENT_TUI_EXIT %s %d" % (run_id, code), flush=True)
    quarantine_tui(run_id)
    return code


class ForwardedSignal(Exception):
    def __init__(self, signum):
        super().__init__(signum)
        self.signum = signum


def process_group_alive(pgid):
    try:
        os.killpg(pgid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True


def stop_process_group(child, signum, grace=TERMINATION_GRACE):
    if child is None:
        return
    if os.name == "nt":
        if child.poll() is None:
            child.terminate()
            try:
                child.wait(timeout=grace)
            except subprocess.TimeoutExpired:
                child.kill()
                child.wait()
        return
    pgid = child.pid
    if process_group_alive(pgid):
        try:
            os.killpg(pgid, signum)
        except ProcessLookupError:
            pass
    deadline = time.monotonic() + grace
    while process_group_alive(pgid) and time.monotonic() < deadline:
        remaining = max(0.0, deadline - time.monotonic())
        if child.poll() is None:
            try:
                child.wait(timeout=min(0.05, remaining))
            except subprocess.TimeoutExpired:
                pass
        else:
            time.sleep(min(0.05, remaining))
    if process_group_alive(pgid):
        try:
            os.killpg(pgid, signal.SIGKILL)
        except ProcessLookupError:
            pass
    if child.poll() is None:
        child.wait()


def control_line(marker):
    tty_state = None
    if sys.stdin.isatty():
        import termios

        tty_state = termios.tcgetattr(sys.stdin.fileno())
        quiet = termios.tcgetattr(sys.stdin.fileno())
        quiet[3] &= ~termios.ECHO
        termios.tcsetattr(sys.stdin.fileno(), termios.TCSADRAIN, quiet)
    try:
        print(marker, flush=True)
        line = sys.stdin.buffer.readline(MAX_LINE + 1)
    finally:
        if tty_state is not None:
            termios.tcsetattr(sys.stdin.fileno(), termios.TCSADRAIN, tty_state)
    if len(line) > MAX_LINE:
        return ""
    return line.rstrip(b"\r\n").decode("ascii", errors="replace")


def supervise_tui(argv, directory, env):
    child = None
    previous_handlers = {}
    tty_fd = sys.stdin.fileno() if sys.stdin.isatty() else None
    parent_pgrp = os.getpgrp()
    tty_state = None
    previous_sigttou = None
    termination_signals = {signal.SIGTERM, signal.SIGHUP}
    previous_mask = signal.pthread_sigmask(signal.SIG_BLOCK, termination_signals)
    mask_restored = False

    def forward_signal(signum, _frame):
        raise ForwardedSignal(signum)

    def prepare_child():
        os.setpgrp()
        for signum in termination_signals:
            signal.signal(signum, signal.SIG_DFL)
        signal.pthread_sigmask(signal.SIG_SETMASK, previous_mask)

    try:
        if tty_fd is not None:
            import termios

            tty_state = termios.tcgetattr(tty_fd)
        for signum in termination_signals:
            previous_handlers[signum] = signal.signal(signum, forward_signal)
        child = subprocess.Popen(
            argv,
            cwd=directory,
            env=env,
            preexec_fn=prepare_child,
        )
        signal.pthread_sigmask(signal.SIG_SETMASK, previous_mask)
        mask_restored = True
        if tty_fd is not None:
            previous_sigttou = signal.signal(signal.SIGTTOU, signal.SIG_IGN)
            try:
                os.tcsetpgrp(tty_fd, child.pid)
            except OSError:
                if child.poll() is None:
                    raise
        code = child.wait()
        return 128 - code if code < 0 else code
    except KeyboardInterrupt:
        stop_process_group(child, signal.SIGINT)
        return 130
    except ForwardedSignal as forwarded:
        stop_process_group(child, forwarded.signum)
        return 128 + forwarded.signum
    except OSError:
        stop_process_group(child, signal.SIGKILL, 0)
        raise
    finally:
        for signum, previous in previous_handlers.items():
            signal.signal(signum, previous)
        if not mask_restored:
            signal.pthread_sigmask(signal.SIG_SETMASK, previous_mask)
        if tty_fd is not None:
            try:
                os.tcsetpgrp(tty_fd, parent_pgrp)
            except OSError:
                pass
            if tty_state is not None:
                import termios

                termios.tcsetattr(tty_fd, termios.TCSADRAIN, tty_state)
            if previous_sigttou is not None:
                signal.signal(signal.SIGTTOU, previous_sigttou)


def quarantine_tui(run_id):
    release = ("WMUX_AGENT_TUI_RELEASE %s" % run_id).encode("ascii")
    tty_state = None
    if sys.stdin.isatty():
        import termios

        tty_state = termios.tcgetattr(sys.stdin.fileno())
        quiet = termios.tcgetattr(sys.stdin.fileno())
        quiet[3] &= ~termios.ECHO
        termios.tcsetattr(sys.stdin.fileno(), termios.TCSADRAIN, quiet)
    try:
        print(
            "Interactive runtime exited; press Ctrl-C to return to the shell "
            "or enter WMUX_AGENT_TUI_RELEASE %s." % run_id,
            flush=True,
        )
        while True:
            try:
                line = sys.stdin.buffer.readline(MAX_LINE + 1)
            except KeyboardInterrupt:
                return
            if not line:
                time.sleep(0.1)
                continue
            if len(line) <= MAX_LINE and line.rstrip(b"\r\n") == release:
                return
    finally:
        if tty_state is not None:
            termios.tcsetattr(sys.stdin.fileno(), termios.TCSADRAIN, tty_state)
            print(flush=True)


def advertised_option(output, option):
    return re.search(r"(?:^|[\s[,])" + re.escape(option) + r"(?=$|[\s=,\]])", output, flags=re.MULTILINE) is not None


def opencode_auto_option(executable, env):
    child = None
    selector = selectors.DefaultSelector()
    captured = bytearray()
    try:
        child = subprocess.Popen(
            [executable, "run", "--help"],
            stdin=subprocess.DEVNULL,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            env=env,
            start_new_session=True,
        )
        assert child.stdout is not None
        os.set_blocking(child.stdout.fileno(), False)
        selector.register(child.stdout, selectors.EVENT_READ)
        deadline = time.monotonic() + HELP_PROBE_TIMEOUT
        eof = False
        while not eof or child.poll() is None:
            remaining = deadline - time.monotonic()
            if remaining <= 0:
                stop_process_group(child, signal.SIGKILL, 0)
                raise ValueError("OpenCode auto-approval capability probe timed out")
            for key, _events in selector.select(min(0.05, remaining)):
                try:
                    chunk = os.read(key.fileobj.fileno(), 8192)
                except BlockingIOError:
                    continue
                if not chunk:
                    selector.unregister(key.fileobj)
                    eof = True
                    continue
                available = MAX_HELP_OUTPUT - len(captured)
                if available > 0:
                    captured.extend(chunk[:available])
        code = child.wait()
    except OSError as error:
        stop_process_group(child, signal.SIGKILL, 0)
        raise ValueError("OpenCode auto-approval capability probe failed") from error
    finally:
        selector.close()
    if code != 0:
        raise ValueError("OpenCode auto-approval capability probe failed")
    output = re.sub(r"\x1b\[[0-?]*[ -/]*[@-~]", "", captured.decode("utf-8", errors="replace"))
    if advertised_option(output, "--auto"):
        return "--auto"
    if advertised_option(output, "--dangerously-skip-permissions"):
        return "--dangerously-skip-permissions"
    raise ValueError("installed OpenCode does not advertise an auto-approval option")


def command_for(request, runtime, directory, env, schema_path=None):
    executable = shutil.which(runtime)
    if not executable:
        raise FileNotFoundError("%s executable not found" % runtime)
    unattended = request.get("unattended") is True
    write_access = request.get("writeAccess", False) is True
    model = request.get("model")
    if runtime == "opencode":
        if not write_access:
            raise ValueError("OpenCode delegation cannot enforce read-only mode; explicitly enable writeAccess")
        argv = [executable, "run", "--format", "json", "--dir", directory]
        if request.get("title"):
            argv.extend(["--title", request["title"]])
        if request.get("agent"):
            argv.extend(["--agent", request["agent"]])
        if model:
            argv.extend(["--model", model])
        if unattended:
            argv.append(opencode_auto_option(executable, env))
        return argv, None
    if runtime == "codex":
        sandbox_mode = request.get("sandboxMode") or ("workspace-write" if write_access else "read-only")
        argv = [executable, "--sandbox", sandbox_mode]
        if unattended:
            argv.extend(["--ask-for-approval", "never"])
        if model:
            argv.extend(["--model", model])
        argv.extend(["exec", "--json", "-C", directory])
        if schema_path:
            argv.extend(["--output-schema", schema_path])
        argv.append("-")
        return argv, None
    argv = [executable, "-p", "--verbose", "--input-format", "text", "--output-format", "stream-json"]
    argv.extend(["--permission-mode", "acceptEdits" if write_access else "plan"])
    if unattended:
        argv.append("--dangerously-skip-permissions")
    if model:
        argv.extend(["--model", model])
    return argv, directory


def prepare_windows_command(argv, platform=None, exists=None, which=None):
    platform = os.name if platform is None else platform
    exists = os.path.isfile if exists is None else exists
    which = shutil.which if which is None else which
    if platform != "nt" or os.path.splitext(argv[0])[1].lower() not in {".bat", ".cmd"}:
        return argv, False
    powershell_script = os.path.splitext(argv[0])[0] + ".ps1"
    powershell = which("pwsh") or which("powershell")
    if powershell and exists(powershell_script):
        return [
            powershell,
            "-NoLogo",
            "-NoProfile",
            "-ExecutionPolicy",
            "Bypass",
            "-File",
            powershell_script,
            *argv[1:],
        ], False
    return argv, True


def nested_text(value):
    if isinstance(value, str):
        return value
    if not isinstance(value, dict):
        return ""
    for key in ("text", "message", "error", "data", "part"):
        nested = nested_text(value.get(key))
        if nested:
            return nested
    return ""


def parse_event(runtime, parsed):
    if not isinstance(parsed, dict):
        return "", ""
    kind = parsed.get("type")
    if runtime == "opencode":
        if kind == "text":
            return nested_text(parsed.get("part")) or nested_text(parsed.get("text")), ""
        if kind == "error":
            return "", nested_text(parsed.get("error")) or nested_text(parsed)
    elif runtime == "codex":
        item = parsed.get("item")
        if kind == "item.completed" and isinstance(item, dict) and item.get("type") == "agent_message":
            return nested_text(item), ""
        if kind in {"error", "turn.failed"}:
            return "", nested_text(parsed)
    elif kind == "result":
        text = nested_text(parsed.get("result"))
        if parsed.get("is_error") is True or parsed.get("subtype") not in {None, "success"}:
            return "", text or nested_text(parsed)
        return text, ""
    return "", ""


def parse_structured_outcome(value):
    try:
        parsed = json.loads(value)
    except (TypeError, json.JSONDecodeError) as error:
        raise ValueError("Codex did not return the required structured outcome") from error
    if not isinstance(parsed, dict):
        raise ValueError("Codex did not return the required structured outcome")
    outcome, summary = parsed.get("outcome"), parsed.get("summary")
    if outcome not in {"completed", "blocked", "failed"} or not isinstance(summary, str) or not summary.strip():
        raise ValueError("Codex returned an invalid structured outcome")
    return outcome, summary.strip()


def main():
    if len(sys.argv) in {2, 3} and sys.argv[1] == "tui":
        expected = sys.argv[2] if len(sys.argv) == 3 else ""
        if expected and not re.fullmatch(r"[A-Za-z0-9._-]{1,128}", expected):
            return fail("unknown", "invalid TUI runId")
        return tui_main(expected)
    expected_run_id = ""
    if len(sys.argv) == 3 and sys.argv[1] == "request":
        expected_run_id = sys.argv[2]
        if not re.fullmatch(r"[A-Za-z0-9._-]{1,128}", expected_run_id):
            return fail("unknown", "invalid request runId")
    elif len(sys.argv) != 1:
        return fail("unknown", "usage: wmux-agent-run [request RUN_ID|tui RUN_ID]")
    run_id = expected_run_id or "unknown"
    schema_path = None
    try:
        marker = "WMUX_AGENT_READY %s" % expected_run_id if expected_run_id else "WMUX_AGENT_READY"
        request = request_from_stdin(marker)
        candidate = request.get("runId")
        if isinstance(candidate, str) and re.fullmatch(r"[A-Za-z0-9._-]{1,128}", candidate):
            run_id = candidate
        if expected_run_id and candidate != expected_run_id:
            raise ValueError("request runId does not match the launched helper")
        run_id, runtime, prompt, directory = validate(request)
        env = os.environ.copy()
        env["WMUX_DELEGATED_RUN"] = "1"
        env["WMUX_DELEGATION_RUN_ID"] = run_id
        if request.get("resultFormat") == "outcome-v1":
            descriptor, schema_path = tempfile.mkstemp(prefix="wmux-agent-outcome-", suffix=".json")
            with os.fdopen(descriptor, "w", encoding="utf-8") as handle:
                json.dump(OUTCOME_SCHEMA, handle, separators=(",", ":"))
            if os.name != "nt":
                os.chmod(schema_path, 0o600)
        argv, cwd = command_for(request, runtime, directory, env, schema_path)
        argv, use_shell = prepare_windows_command(argv)
    except FileNotFoundError as error:
        if schema_path:
            try:
                os.unlink(schema_path)
            except OSError:
                pass
        return fail(run_id, str(error), 127)
    except ValueError as error:
        if schema_path:
            try:
                os.unlink(schema_path)
            except OSError:
                pass
        return fail(run_id, str(error))

    result, error, last_text = "", "", ""
    prompt_forms = {prompt, json.dumps(prompt, ensure_ascii=False)[1:-1], json.dumps(prompt)[1:-1]}
    child = None
    previous_handlers = {}

    def forward_signal(signum, _frame):
        raise ForwardedSignal(signum)

    forwarded_signals = tuple(
        candidate for candidate in (getattr(signal, "SIGTERM", None), getattr(signal, "SIGHUP", None))
        if candidate is not None
    )
    for signum in forwarded_signals:
        previous_handlers[signum] = signal.signal(signum, forward_signal)
    try:
        child = subprocess.Popen(
            argv,
            cwd=cwd,
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            encoding="utf-8",
            errors="replace",
            env=env,
            shell=use_shell,
            start_new_session=os.name != "nt",
            creationflags=subprocess.CREATE_NEW_PROCESS_GROUP if os.name == "nt" else 0,
        )
        assert child.stdin is not None and child.stdout is not None
        child.stdin.write(prompt)
        child.stdin.close()
        for line in child.stdout:
            visible = line
            for prompt_form in prompt_forms:
                if prompt_form:
                    visible = visible.replace(prompt_form, "[redacted]")
            sys.stdout.write(visible)
            sys.stdout.flush()
            try:
                parsed = json.loads(line)
            except json.JSONDecodeError:
                continue
            text, failure = parse_event(runtime, parsed)
            if text:
                result = append_bounded(result, text)
                last_text = text
            if failure:
                error = append_bounded(error, failure)
        code = child.wait()
    except KeyboardInterrupt:
        stop_process_group(child, signal.SIGINT)
        return fail(run_id, "cancelled by Ctrl-C", 130)
    except ForwardedSignal as forwarded:
        stop_process_group(child, forwarded.signum)
        return 128 + forwarded.signum
    except OSError as exc:
        stop_process_group(child, getattr(signal, "SIGKILL", signal.SIGTERM), 0)
        return fail(run_id, str(exc), 127)
    finally:
        for signum, previous in previous_handlers.items():
            signal.signal(signum, previous)
        if schema_path:
            try:
                os.unlink(schema_path)
            except OSError:
                pass
    outcome = "completed"
    if request.get("resultFormat") == "outcome-v1" and not error:
        try:
            outcome, result = parse_structured_outcome(last_text)
        except ValueError as exc:
            outcome, error = "failed", str(exc)
    elif code != 0 or error:
        outcome = "failed"
    ok = code == 0 and not error and outcome == "completed"
    if outcome != "completed" and not error:
        error = result
    payload = {
        "runId": run_id,
        "runtime": runtime,
        "ok": ok,
        "result": bounded(result),
        "error": bounded(error),
    }
    if request.get("resultFormat") == "outcome-v1":
        payload["outcome"] = outcome
    emit("WMUX_AGENT_RESULT", payload)
    print("WMUX_AGENT_DONE %s %d" % (run_id, code), flush=True)
    return code


if __name__ == "__main__":
    sys.exit(main())
