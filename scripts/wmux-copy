#!/usr/bin/env python3
import argparse
import json
import os
import re
import sys
import urllib.request


def _wmux_url():
    url = os.environ.get("WMUX_URL")
    if url:
        return url
    # ~/.wmux/url is persisted alongside ~/.wmux/token by wmux.
    try:
        with open(os.path.expanduser("~/.wmux/url"), "r", encoding="utf-8") as handle:
            url = handle.read().strip()
    except OSError:
        url = ""
    return url or "http://127.0.0.1:3478"


def _wmux_token():
    env_configured = "WMUX_HELPER_TOKEN" in os.environ
    env_token = os.environ.get("WMUX_HELPER_TOKEN", "").strip()
    if env_configured and not re.fullmatch(r"[A-Za-z0-9_-]{32,256}", env_token):
        raise SystemExit(f"{command_name}: configured helper token is empty or malformed")
    path_configured = "WMUX_HELPER_TOKEN_PATH" in os.environ
    path_value = os.environ.get("WMUX_HELPER_TOKEN_PATH", "").strip()
    if path_configured and not path_value:
        raise SystemExit(f"{command_name}: configured helper token path is empty")
    path = path_value if path_configured else os.path.expanduser("~/.wmux/helper-token")
    if path_configured or os.path.exists(path):
        try:
            with open(path, "r", encoding="utf-8") as handle:
                token = handle.read().strip()
        except OSError:
            token = ""
        if not re.fullmatch(r"[A-Za-z0-9_-]{32,256}", token):
            raise SystemExit(f"{command_name}: configured helper token file is unreadable or malformed")
        return token
    if env_configured:
        return env_token
    if os.environ.get("WMUX_BROWSER_AUTH_MODE", "shared-or-login") == "login-only":
        return ""
    token = os.environ.get("WMUX_TOKEN")
    if token:
        return token
    path = os.environ.get("WMUX_TOKEN_PATH") or os.path.expanduser("~/.wmux/token")
    try:
        with open(path, "r", encoding="utf-8") as handle:
            return handle.read().strip()
    except OSError:
        return ""


def _wmux_auth_headers():
    token = _wmux_token()
    return {"authorization": "Bearer " + token} if token else {}


command_name = os.environ.get("WMUX_COPY_PROG") or os.path.basename(sys.argv[0]) or "wmux-copy"


def read_input(path: str | None) -> str:
    if path:
        with open(path, "rb") as handle:
            data = handle.read()
    else:
        if sys.stdin.isatty():
            raise ValueError(f"{command_name} requires stdin or a file")
        data = sys.stdin.buffer.read()
    return data.decode("utf-8", errors="replace")


parser = argparse.ArgumentParser(prog=command_name)
parser.add_argument("--url", default=_wmux_url())
parser.add_argument("--pane", default=os.environ.get("WMUX_PANE_ID", ""))
parser.add_argument("--workspace", default=os.environ.get("WMUX_WORKSPACE_ID", ""))
parser.add_argument("--tab", default=os.environ.get("WMUX_TAB_ID", ""))
parser.add_argument("file", nargs="?")
args = parser.parse_args()

try:
    text = read_input(args.file)
except ValueError as error:
    parser.error(str(error))

if not text:
    print(f"{command_name}: no input", file=sys.stderr)
    sys.exit(2)

payload = {"text": text}
if args.pane:
    payload["paneId"] = args.pane
if args.workspace:
    payload["workspaceId"] = args.workspace
if args.tab:
    payload["tabId"] = args.tab

request = urllib.request.Request(
    args.url.rstrip("/") + "/api/clipboard",
    data=json.dumps(payload).encode("utf-8"),
    headers={"content-type": "application/json", **_wmux_auth_headers()},
    method="POST",
)
with urllib.request.urlopen(request, timeout=15):
    pass
