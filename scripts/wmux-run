#!/usr/bin/env python3
import argparse
import datetime
import json
import os
import re
import subprocess
import sys
import uuid
import urllib.request


def _wmux_url():
    url = os.environ.get("WMUX_URL")
    if url:
        return url
    # ~/.wmux/url is persisted alongside ~/.wmux/token by wmux.
    try:
        with open(os.path.expanduser("~/.wmux/url"), "r", encoding="utf-8") as handle:
            url = handle.read().strip()
    except OSError:
        url = ""
    return url or "http://127.0.0.1:3478"


def _wmux_token():
    env_configured = "WMUX_HELPER_TOKEN" in os.environ
    env_token = os.environ.get("WMUX_HELPER_TOKEN", "").strip()
    if env_configured and not re.fullmatch(r"[A-Za-z0-9_-]{32,256}", env_token):
        raise SystemExit("wmux-run: configured helper token is empty or malformed")
    path_configured = "WMUX_HELPER_TOKEN_PATH" in os.environ
    path_value = os.environ.get("WMUX_HELPER_TOKEN_PATH", "").strip()
    if path_configured and not path_value:
        raise SystemExit("wmux-run: configured helper token path is empty")
    path = path_value if path_configured else os.path.expanduser("~/.wmux/helper-token")
    if path_configured or os.path.exists(path):
        try:
            with open(path, "r", encoding="utf-8") as handle:
                token = handle.read().strip()
        except OSError:
            token = ""
        if not re.fullmatch(r"[A-Za-z0-9_-]{32,256}", token):
            raise SystemExit("wmux-run: configured helper token file is unreadable or malformed")
        return token
    if env_configured:
        return env_token
    if os.environ.get("WMUX_BROWSER_AUTH_MODE", "shared-or-login") == "login-only":
        return ""
    token = os.environ.get("WMUX_TOKEN")
    if token:
        return token
    path = os.environ.get("WMUX_TOKEN_PATH") or os.path.expanduser("~/.wmux/token")
    try:
        with open(path, "r", encoding="utf-8") as handle:
            return handle.read().strip()
    except OSError:
        return ""


def _wmux_auth_headers():
    token = _wmux_token()
    return {"authorization": "Bearer " + token} if token else {}


def utc_now():
    return datetime.datetime.now(datetime.timezone.utc).isoformat().replace("+00:00", "Z")


def clean_command(command):
    return re.sub(r"\s+", " ", " ".join(command)).strip()[:500]


def post_json(url, payload):
    request = urllib.request.Request(
        url.rstrip("/") + "/api/run-events",
        data=json.dumps(payload).encode("utf-8"),
        headers={"content-type": "application/json", **_wmux_auth_headers()},
        method="POST",
    )
    try:
        with urllib.request.urlopen(request, timeout=5):
            pass
    except Exception:
        return


def main():
    parser = argparse.ArgumentParser(prog="wmux-run")
    parser.add_argument("--url", default=_wmux_url())
    parser.add_argument("--pane", default=os.environ.get("WMUX_PANE_ID", ""))
    parser.add_argument("--workspace", default=os.environ.get("WMUX_WORKSPACE_ID", ""))
    parser.add_argument("--tab", default=os.environ.get("WMUX_TAB_ID", ""))
    parser.add_argument("command", nargs=argparse.REMAINDER)
    args = parser.parse_args()

    command = args.command
    if command and command[0] == "--":
        command = command[1:]
    if not command:
        parser.error("command is required")

    started_at = utc_now()
    run_id = "run_" + uuid.uuid4().hex[:18]
    display_command = clean_command(command)
    payload = {
        "runId": run_id,
        "command": display_command,
        "status": "started",
        "startedAt": started_at,
    }
    if args.pane:
        payload["paneId"] = args.pane
    if args.workspace:
        payload["workspaceId"] = args.workspace
    if args.tab:
        payload["tabId"] = args.tab

    if args.pane or args.workspace:
        post_json(args.url, payload)

    try:
        exit_code = subprocess.call(command)
    except FileNotFoundError:
        print(f"wmux-run: command not found: {command[0]}", file=sys.stderr)
        exit_code = 127

    if args.pane or args.workspace:
        payload.update(
            {
                "status": "completed" if exit_code == 0 else "failed",
                "exitCode": exit_code,
                "completedAt": utc_now(),
            }
        )
        post_json(args.url, payload)
    return exit_code


if __name__ == "__main__":
    raise SystemExit(main())
