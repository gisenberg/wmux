#!/usr/bin/env bash
set -euo pipefail

wmux_url="${WMUX_URL:-}"
if [[ -z "${wmux_url}" && -r "${HOME}/.wmux/url" ]]; then
  # ~/.wmux/url is persisted alongside ~/.wmux/token by wmux.
  wmux_url="$(tr -d '[:space:]' < "${HOME}/.wmux/url")"
fi
wmux_url="${wmux_url:-http://127.0.0.1:3478}"
title="wmux"
subtitle=""
body=""
pane_id="${WMUX_PANE_ID:-}"
workspace_id="${WMUX_WORKSPACE_ID:-}"
tab_id="${WMUX_TAB_ID:-}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --url)
      wmux_url="${2:?--url requires a value}"
      shift 2
      ;;
    --title)
      title="${2:?--title requires a value}"
      shift 2
      ;;
    --subtitle)
      subtitle="${2:?--subtitle requires a value}"
      shift 2
      ;;
    --body)
      body="${2:?--body requires a value}"
      shift 2
      ;;
    --pane)
      pane_id="${2:?--pane requires a value}"
      shift 2
      ;;
    --workspace)
      workspace_id="${2:?--workspace requires a value}"
      shift 2
      ;;
    --tab)
      tab_id="${2:?--tab requires a value}"
      shift 2
      ;;
    *)
      if [[ -z "${body}" ]]; then
        body="$1"
        shift
      else
        echo "unknown argument: $1" >&2
        exit 2
      fi
      ;;
  esac
done

json_escape() {
  node -e 'let s="";process.stdin.on("data",d=>s+=d);process.stdin.on("end",()=>process.stdout.write(JSON.stringify(s)))'
}

load_wmux_token() {
  local token="" token_file="" scoped=0 env_configured=0 env_token=""
  if [[ "${WMUX_HELPER_TOKEN+x}" == x ]]; then
    env_token="${WMUX_HELPER_TOKEN}"
    env_configured=1
    [[ "${env_token}" =~ ^[A-Za-z0-9_-]{32,256}$ ]] || { echo "wmux-notify: configured helper token is empty or malformed" >&2; return 1; }
  fi
  if [[ "${WMUX_HELPER_TOKEN_PATH+x}" == x ]]; then
    token_file="${WMUX_HELPER_TOKEN_PATH}"
    scoped=1
  elif [[ -e "${HOME}/.wmux/helper-token" ]]; then
    token_file="${HOME}/.wmux/helper-token"
    scoped=1
  fi
  if [[ -n "${token_file}" ]]; then
    [[ -f "${token_file}" && -r "${token_file}" ]] || { echo "wmux-notify: configured helper token file is unreadable" >&2; return 1; }
    token="$(tr -d '[:space:]' < "${token_file}")"
  fi
  if [[ "${scoped}" -eq 1 ]]; then
    [[ "${token}" =~ ^[A-Za-z0-9_-]{32,256}$ ]] || { echo "wmux-notify: configured helper token is empty or malformed" >&2; return 1; }
    printf '%s' "${token}"
    return
  fi
  if [[ "${env_configured}" -eq 1 ]]; then printf '%s' "${env_token}"; return; fi
  [[ "${WMUX_BROWSER_AUTH_MODE:-shared-or-login}" == "shared-or-login" ]] || return
  token="${WMUX_TOKEN:-}"
  if [[ -z "${token}" ]]; then
    token_file="${WMUX_TOKEN_PATH:-${HOME}/.wmux/token}"
    [[ -r "${token_file}" ]] && token="$(tr -d '[:space:]' < "${token_file}")"
  fi
  printf '%s' "${token}"
}

payload="{\"title\":$(printf '%s' "$title" | json_escape),\"subtitle\":$(printf '%s' "$subtitle" | json_escape),\"body\":$(printf '%s' "$body" | json_escape)"
if [[ -n "${pane_id}" ]]; then
  payload="${payload},\"paneId\":$(printf '%s' "$pane_id" | json_escape)"
fi
if [[ -n "${workspace_id}" ]]; then
  payload="${payload},\"workspaceId\":$(printf '%s' "$workspace_id" | json_escape)"
fi
if [[ -n "${tab_id}" ]]; then
  payload="${payload},\"tabId\":$(printf '%s' "$tab_id" | json_escape)"
fi
payload="${payload}}"

wmux_token="$(load_wmux_token)"
auth_header=()
if [[ -n "${wmux_token}" ]]; then
  auth_header=(-H "Authorization: Bearer ${wmux_token}")
fi

curl -fsS \
  -H "content-type: application/json" \
  "${auth_header[@]}" \
  -d "${payload}" \
  "${wmux_url%/}/api/notifications" >/dev/null
