{
  "terminalFontFamily": "\"MesloLGM Nerd Font\"",
  "terminalFontSize": 15,
  "delegation": {
    "waitTimeoutSeconds": {
      "review": 1800,
      "change": 7200,
      "deploy": 7200
    }
  },
  "keybindings": {
    "commandPalette.open": ["Meta+KeyK", "Ctrl+KeyK"],
    "settings.open": [],
    "sidebar.toggle": ["Meta+KeyB", "Ctrl+KeyB"],
    "workspace.new": ["Meta+KeyN", "Ctrl+KeyN"],
    "workspace.close": ["Meta+Shift+KeyW", "Ctrl+Shift+KeyW"],
    "workspace.previous": ["Meta+Ctrl+BracketLeft", "Ctrl+Alt+BracketLeft"],
    "workspace.next": ["Meta+Ctrl+BracketRight", "Ctrl+Alt+BracketRight"],
    "workspace.select1": ["Meta+Digit1", "Ctrl+Digit1"],
    "workspace.select2": ["Meta+Digit2", "Ctrl+Digit2"],
    "workspace.select3": ["Meta+Digit3", "Ctrl+Digit3"],
    "workspace.select4": ["Meta+Digit4", "Ctrl+Digit4"],
    "workspace.select5": ["Meta+Digit5", "Ctrl+Digit5"],
    "workspace.select6": ["Meta+Digit6", "Ctrl+Digit6"],
    "workspace.select7": ["Meta+Digit7", "Ctrl+Digit7"],
    "workspace.select8": ["Meta+Digit8", "Ctrl+Digit8"],
    "workspace.select9": ["Meta+Digit9", "Ctrl+Digit9"],
    "tab.new": ["Meta+KeyT", "Ctrl+KeyT"],
    "tab.close": ["Meta+KeyW", "Ctrl+KeyW"],
    "tab.previous": ["Meta+Shift+BracketLeft", "Ctrl+Shift+BracketLeft", "Ctrl+Shift+Tab"],
    "tab.next": ["Meta+Shift+BracketRight", "Ctrl+Shift+BracketRight", "Ctrl+Tab"],
    "tab.select1": ["Alt+Digit1"],
    "tab.select2": ["Alt+Digit2"],
    "tab.select3": ["Alt+Digit3"],
    "tab.select4": ["Alt+Digit4"],
    "tab.select5": ["Alt+Digit5"],
    "tab.select6": ["Alt+Digit6"],
    "tab.select7": ["Alt+Digit7"],
    "tab.select8": ["Alt+Digit8"],
    "tab.select9": ["Alt+Digit9"],
    "pane.splitRight": ["Meta+KeyD", "Ctrl+KeyD"],
    "pane.splitDown": ["Meta+Shift+KeyD", "Ctrl+Shift+KeyD"],
    "pane.focusPrevious": ["Meta+Alt+ArrowLeft", "Meta+Alt+ArrowUp", "Ctrl+Alt+ArrowLeft", "Ctrl+Alt+ArrowUp"],
    "pane.focusNext": ["Meta+Alt+ArrowRight", "Meta+Alt+ArrowDown", "Ctrl+Alt+ArrowRight", "Ctrl+Alt+ArrowDown"],
    "notification.latestUnread": ["Meta+Shift+KeyU", "Ctrl+Shift+KeyU"],
    "terminal.insertNewline": ["Shift+Enter"],
    "terminal.wordPrevious": ["Alt+ArrowLeft"],
    "terminal.wordNext": ["Alt+ArrowRight"],
    "settings.save": ["Meta+KeyS", "Ctrl+KeyS"]
  },
  "machines": [
    {
      "id": "local",
      "name": "Local",
      "kind": "local",
      "sessionBackend": "auto"
    },
    {
      "id": "linux-box",
      "name": "Linux Box",
      "kind": "ssh",
      "platform": "linux",
      "host": "100.64.0.20",
      "user": "operator",
      "port": 22,
      "sessionBackend": "auto"
    },
    {
      "id": "windows-box",
      "name": "Windows Box",
      "kind": "powershell-ssh",
      "platform": "win",
      "host": "100.64.0.30",
      "user": "operator",
      "port": 22,
      "sessionBackend": "agent",
      "agentPort": 3481,
      "loadPowerShellProfile": true
    }
  ]
}
